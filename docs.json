{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Geval Documentation",
  "description": "Eval-driven release gates for AI applications",
  "colors": {
    "primary": "#10b981",
    "light": "#34d399",
    "dark": "#022c22"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://geval.io/white_bg_greenlogo.svg",
    "dark": "https://geval.io/white_bg_greenlogo.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "getting-started"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/check",
              "cli/diff",
              "cli/explain",
              "cli/validate"
            ]
          },
          {
            "group": "Contracts",
            "pages": [
              "contracts/overview",
              "contracts/aggregation",
              "contracts/operators",
              "contracts/sources"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "integration/github-actions",
              "integration/gitlab-ci",
              "integration/exit-codes"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "api/overview",
              "api/core-functions",
              "api/adapters",
              "api/types"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/performance",
              "examples/safety",
              "examples/multi-eval"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.geval.io",
          "icon": "book-open-cover"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/geval-labs/geval",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/geval-labs/geval"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Early Access",
      "href": "https://geval.io#waitlist"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/geval_labs",
      "github": "https://github.com/geval-labs/geval",
      "linkedin": "https://linkedin.com/company/geval-labs"
    }
  }
}
